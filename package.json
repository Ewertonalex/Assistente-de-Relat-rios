{
  "name": "assistente-relatorios-cbtu",
  "version": "1.0.0",
  "description": "Assistente de IA para relatórios dos ASO Seguranças CBTU",
  "type": "module",
  "scripts": {
    "dev": "npm run kill-port 2>/dev/null; concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "kill-port": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "dev:server": "dotenv -e .env -- node run-server.js",
    "dev:client": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "dotenv -e .env -- node run-server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "groq-sdk": "^0.5.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-signature-canvas": "^1.0.6"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "dotenv-cli": "^11.0.0",
    "vite": "^5.4.10"
  }
}
